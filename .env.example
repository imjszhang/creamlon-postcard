CREAMLON_PATH=D:\github\My\js-creamlon
CREAMLON_NODE_REPO=imjszhang/creamlon-postcard
GITHUB_TOKEN=

# Optional split-token mode. If unset, scripts fall back to GITHUB_TOKEN/GH_TOKEN.
# Use public token for seller repo Issues/trust operations, and inbox token for
# buyer private inbox contents read/write.
CREAMLON_PUBLIC_GITHUB_TOKEN=
CREAMLON_INBOX_GITHUB_TOKEN=

# Vendor defaults:
PORT=8787
PUBLIC_BASE_URL=http://localhost:8787
CREAMLON_CREDENTIAL_TTL_SECONDS=3600
POSTCARD_PER_GITHUB_LIMIT=3

# Auto-delivery safety defaults:
POSTCARD_GITHUB_TIMEOUT_MS=30000
POSTCARD_TASK_TIMEOUT_MS=120000
POSTCARD_TASK_DELAY_MS=1000
POSTCARD_KEEP_ARTIFACTS=false
