PORT=8787
PUBLIC_BASE_URL=http://localhost:8787

# Defaults to ../js-creamlon/bin/creamlon.mjs relative to this repo.
# Set this if your js-creamlon checkout lives elsewhere.
CREAMLON_ENTRY=D:\github\My\js-creamlon\bin\creamlon.mjs

# Defaults to the creamlon-postcard repo root.
CREAMLON_REPO_PATH=D:\github\My\creamlon-postcard

CREAMLON_CREDENTIAL_TTL_SECONDS=3600
POSTCARD_PER_GITHUB_LIMIT=3
ISSUANCE_STORE=D:\github\My\creamlon-postcard\.data\issuance.json
